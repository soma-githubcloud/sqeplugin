# Generated by sqe-kit | Kit: {{kitId}} | {{generatedDate}}
# GitHub Actions CI pipeline for {{projectName}}
# Regenerate with: /sqe-kit:generate-automation-tests --ci github

name: UI-Playwright — {{projectName}}

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
  workflow_dispatch:
{{#if schedule}}
  schedule:
    - cron: '0 2 * * *'   # Nightly at 2 AM UTC
{{/if}}

env:
  NODE_VERSION: '20'

jobs:
  smoke-test:
    name: Smoke Tests{{#if matrix}} — {{"{{"}} matrix.browser {{"}}"}}{{/if}}
    runs-on: ubuntu-latest
    {{#if matrix}}
    strategy:
      fail-fast: false
      matrix:
        browser: [chromium, firefox, webkit]
    {{/if}}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js ${{"{{"}} env.NODE_VERSION {{"}}"}}
        uses: actions/setup-node@v4
        with:
          node-version: ${{"{{"}} env.NODE_VERSION {{"}}"}}
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Install Playwright browsers
        run: npx playwright install {{#if matrix}}${{"{{"}} matrix.browser {{"}}"}}{{else}}chromium{{/if}} --with-deps

      - name: Run smoke tests
        run: npx playwright test --grep "@smoke"{{#if matrix}} --project=${{"{{"}} matrix.browser {{"}}"}}{{/if}}
        env:
          BASE_URL: ${{"{{"}} secrets.BASE_URL {{"}}"}}
          CI: true

      - name: Generate Allure report
        if: always()
        run: npx allure generate allure-results --clean -o allure-report

      - name: Upload Allure report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: allure-report{{#if matrix}}-${{"{{"}} matrix.browser {{"}}"}}{{/if}}
          path: allure-report
          retention-days: 30

      - name: Upload Playwright HTML report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: playwright-report{{#if matrix}}-${{"{{"}} matrix.browser {{"}}"}}{{/if}}
          path: playwright-report
          retention-days: 30
{{#if publishToAllureServer}}

      - name: Publish to Allure Server
        if: always()
        run: |
          npx allure-commandline send \
            --server-url ${{"{{"}} secrets.ALLURE_SERVER_URL {{"}}"}} \
            --project-id {{projectName}} \
            allure-results
{{/if}}
