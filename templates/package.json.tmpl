{
  "name": "{{projectName}}-tests",
  "version": "1.0.0",
  "description": "Playwright TypeScript test automation — generated by sqe-kit ({{kitId}})",
  "private": true,
  "scripts": {
    "test":           "playwright test",
    "test:headed":    "playwright test --headed",
    "test:debug":     "playwright test --debug",
    "test:smoke":     "playwright test --grep @smoke",
    "test:regression":"playwright test --grep @regression",
    "test:ci":        "CI=true playwright test",
    "test:allure":    "playwright test && npm run allure:generate",
    "allure:generate":"allure generate allure-results --clean -o allure-report",
    "allure:open":    "allure open allure-report",
    "report":         "playwright show-report",
    "lint":           "tsc --noEmit",
    "clean":          "rimraf allure-results allure-report playwright-report test-results"{{#if bdd}},
    "test:bdd":       "cucumber-js",
    "test:bdd:dry":   "cucumber-js --dry-run"
    {{/if}}
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "allure-playwright": "^3.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0"{{#if bdd}},
    "@cucumber/cucumber": "^10.0.0",
    "@cucumber/playwright": "^0.0.1",
    "allure-cucumberjs": "^3.0.0",
    "ts-node": "^10.9.0"
    {{/if}}
  }
}
